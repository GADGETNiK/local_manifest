<?xml version="1.0" encoding="UTF-8"?>
<manifest>

   <remote name="tree"
           fetch="https://github.com/LineageOS"
           revision="lineage-19.1"/>

   <remote name="hals"
           fetch="https://github.com/afterallafk"
           revision="12"/>

   <remote name="vendor"
           fetch="https://github.com/Fuss-in-android"
           revision="lineage-19.1"/>

 <!-- Device Trees -->
  <project path="device/xiaomi/onclite" name="android_device_xiaomi_onclite" remote="tree"/>
 
 <!-- Kernel -->
  <project path="kernel/xiaomi/onclite" name="android_kernel_xiaomi_onclite" remote="tree"/>

 <!-- Vendor Trees -->
  <project path="vendor/xiaomi/onclite" name="android_vendor_onclite" remote="vendor"/>

  <remove-project name="ForkLineageOS/hardware_qcom_audio"/>
  <project path="hardware/qcom/audio" name="hardware_qcom-caf_msm8996_audio" remote="hals"/>

  <remove-project name="ForkLineageOS/hardware_qcom_media"/>
  <project path="hardware/qcom/media" name="hardware_qcom-caf_msm8996_media" remote="hals"/>

  <remove-project name="ForkLineageOS/hardware_qcom_display"/>  
  <project path="hardware/qcom-caf/msm8996/display" name="hardware_qcom-caf_msm8996_display" remote="hals"/>

  <remove-project name="ForkLineageOS/hardware_qcom-caf_wlan"/>  
  <project path="hardware/qcom-caf/wlan" name="hardware_qcom-caf_wlan" remote="hals"/>

</manifest>
