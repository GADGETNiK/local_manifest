<?xml version="1.0" encoding="UTF-8"?>
<manifest>

   <remote name="tree"
           fetch="https://github.com/LineageOS"
           revision="lineage-19.1"/>

   <remote name="vendor"
           fetch="https://github.com/Fuss-in-android"
           revision="lineage-19.1"/>

   <remote name="hals"
           fetch="https://github.com/afterallafk"
           revision="12"/>
  


  <!-- nuke stuff -->
  <remove project name="LineageOS/android_hardware_qcom_audio"/>
  <remove project name="LineageOS/android_hardware_qcom_display"/>
  <remove project name="LineageOS/android_hardware_qcom_media"/>
  <remove project name="LineageOS/android_hardware_qcom_wlan"/> 

 <!-- Device Trees -->
  <project path="device/xiaomi/onclite" name="android_device_xiaomi_onclite" remote="tree"/>
 
 <!-- Kernel -->
  <project path="kernel/xiaomi/onclite" name="android_kernel_xiaomi_onclite" remote="tree"/>

 <!-- Vendor Trees -->
  <project path="vendor/xiaomi/onclite" name="android_vendor_onclite" remote="vendor"/>

 <!-- HAL's -->
  <project path="hardware/qcom-caf/msm8996/audio" name="android_hardware_qcom-caf_msm8996_audio" groups="qcom,qcom_audio,pdk-qcom" remote="hals"/>
  <project path="hardware/qcom-caf/msm8996/display" name="android_hardware_qcom-caf_msm8996_display" groups="pdk-qcom,qcom,qcom_display" remote="hals"/>
  <project path="hardware/qcom-caf/msm8996/media" name="android_hardware_qcom-caf_msm8996_media" groups="qcom,pdk-qcom" remote="hals"/>
  <project path="hardware/qcom/wlan" name="android_hardware_qcom-caf_wlan" groups="qcom_wlan,pdk-qcom" remote="hals"/>

</manifest>
